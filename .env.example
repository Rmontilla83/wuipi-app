# ===========================================
# WUIPI APP - Environment Variables
# ===========================================
# Copy to .env.local and fill in values

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- PRTG Network Monitor (legacy) ---
PRTG_SERVER_URL=https://prtg.yourdomain.com
PRTG_USERNAME=your-prtg-username
PRTG_PASSHASH=your-prtg-passhash

# --- Zabbix Monitoring ---
ZABBIX_URL=http://45.181.126.127:61424/zabbix/api_jsonrpc.php
ZABBIX_AUTH_TOKEN=your-zabbix-auth-token

# --- Kommo CRM ---
KOMMO_SUBDOMAIN=your-subdomain
KOMMO_ACCESS_TOKEN=your-access-token
KOMMO_REFRESH_TOKEN=your-refresh-token
KOMMO_CLIENT_ID=your-client-id
KOMMO_CLIENT_SECRET=your-client-secret

# --- Bequant QoE ---
BEQUANT_URL=
BEQUANT_USER=
BEQUANT_PASSWORD=

# --- BCV Rate ---
BCV_MANUAL_RATE=78.50

# === MERCANTIL PAYMENT GATEWAY (Multi-Product) ===
# Cada producto tiene sus propias credenciales (MerchantID, SecretKey, ClientId)
# Base URL Sandbox: https://apimbu.mercantilbanco.com/mercantil-banco/sandbox
# Base URL Produccion: https://apimbu.mercantilbanco.com/mercantil-banco/prod

MERCANTIL_ENVIRONMENT=sandbox
MERCANTIL_INTEGRATOR_ID=
MERCANTIL_TERMINAL_ID=
MERCANTIL_WEBHOOK_URL=https://wuipi-app.vercel.app/api/mercantil/webhook
MERCANTIL_RETURN_URL=https://wuipi.net
# MERCANTIL_BASE_URL=  # Optional override

# --- Producto 1: Pagos con Tarjetas TDD/TDC ---
MERCANTIL_CARDS_MERCHANT_ID=
MERCANTIL_CARDS_SECRET_KEY=
MERCANTIL_CARDS_CLIENT_ID=

# --- Producto 2: Pago Movil C2P ---
MERCANTIL_C2P_MERCHANT_ID=
MERCANTIL_C2P_SECRET_KEY=
MERCANTIL_C2P_CLIENT_ID=

# --- Producto 3: Solicitud Clave C2P ---
MERCANTIL_C2P_KEY_MERCHANT_ID=
MERCANTIL_C2P_KEY_SECRET_KEY=
MERCANTIL_C2P_KEY_CLIENT_ID=

# --- Producto 4: Busqueda de Pagos (Tarjetas) ---
MERCANTIL_SEARCH_CARDS_MERCHANT_ID=
MERCANTIL_SEARCH_CARDS_SECRET_KEY=
MERCANTIL_SEARCH_CARDS_CLIENT_ID=

# --- Producto 5: Busqueda Movil ---
MERCANTIL_SEARCH_MOBILE_MERCHANT_ID=
MERCANTIL_SEARCH_MOBILE_SECRET_KEY=
MERCANTIL_SEARCH_MOBILE_CLIENT_ID=

# --- Producto 6: Busqueda de Transferencias (Client-Id DIFERENTE) ---
MERCANTIL_SEARCH_TRANSFER_MERCHANT_ID=
MERCANTIL_SEARCH_TRANSFER_SECRET_KEY=
MERCANTIL_SEARCH_TRANSFER_CLIENT_ID=

# --- Producto 7: Agendamiento de Cuotas ---
MERCANTIL_SCHEDULING_MERCHANT_ID=
MERCANTIL_SCHEDULING_SECRET_KEY=
MERCANTIL_SCHEDULING_CLIENT_ID=
MERCANTIL_SCHEDULING_CARDS_CLIENT_ID=

# --- Producto 8: TED ---
MERCANTIL_TED_MERCHANT_ID=
MERCANTIL_TED_SECRET_KEY=
MERCANTIL_TED_CLIENT_ID=

# --- Producto 9: Boton de Pagos Web (PENDIENTE) ---
MERCANTIL_WEB_BUTTON_MERCHANT_ID=
MERCANTIL_WEB_BUTTON_SECRET_KEY=
MERCANTIL_WEB_BUTTON_CLIENT_ID=

# --- AI Engines ---
ANTHROPIC_API_KEY=your-anthropic-api-key
GEMINI_API_KEY=your-gemini-api-key
